generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

// ==========================================
// DIRETORIA JIM CARREY
// ==========================================

model Produto {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  nome        String
  descricao   String
  preco       Float

  // Relação N:N com Categorias
  categoriaIds String[]   @db.ObjectId
  categorias   Categoria[] @relation(fields: [categoriaIds], references: [id])

  // Relação N:N com Compras
  compraIds    String[]   @db.ObjectId
  compras      Compra[]   @relation(fields: [compraIds], references: [id])
}

model Categoria {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  nome        String

  // Relação N:N com Produtos
  produtoIds  String[]    @db.ObjectId
  produtos    Produto[]   @relation(fields: [produtoIds], references: [id])
}

model Compra {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  precoTotal  Float
  status      String      @default("pending")

  // Relação 1:N com User
  userId      String      // Sem @db.ObjectId porque o ID do User do Better Auth é uma String normal
  user        User        @relation(fields: [userId], references: [id])

  // Relação N:N com Produtos
  produtoIds  String[]    @db.ObjectId
  produtos    Produto[]   @relation(fields: [produtoIds], references: [id])
}
// ==========================================
// MODELOS DO BETTER AUTH (SISTEMA DE USUÁRIO)
// ==========================================

model User {
  // nao mexer entre aqui >
  id            String    @id @map("_id") // o id do user deve ser assim por causa do better auth
  name          String
  email         String    @unique
  emailVerified Boolean?
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]
  role          Role      @default(USER)
  // < e aqui

  // Nossa nova relação: Um usuário tem várias compras
  compras       Compra[]

  @@map("user")
}

// evitar mexer daqui pra baixo
// nesses 3 modelos do better auth
model Session {
  id        String   @id @map("_id")
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id @map("_id")
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id @map("_id")
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}